# Ignore everything by default
*

# Allow public website directories
!assets/
!assets/**
# Citation & INFO evidence images are public (Trust Loop screenshots)
!data/
!data/**
!foundations/
!foundations/**
!learn/
!learn/**
!neurodivergence/
!neurodivergence/**
!pages/
!pages/**
!patterns/
!patterns/**
!quiz/
!quiz/**
!tools/
!tools/**
!Audit/
!Audit/**
!benchmarks/
!benchmarks/**

# Allow public root files (only what's needed to run the site)
!404.html
!app.js
!favicon.svg
!index.html
!sitemap.xml
!styles.css

# Everything else is local only -- not tracked on GitHub

# Exclude scripts/tools from whitelisted directories
*.py
*.bat
*.ps1
*.sh

# Allow gitignore itself
!.gitignore
